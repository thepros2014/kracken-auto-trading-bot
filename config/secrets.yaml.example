# Kraken API Credentials
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Copy to secrets.yaml and fill in your actual credentials

kraken:
  api_key: YOUR_KRAKEN_API_KEY_HERE
  api_secret: YOUR_KRAKEN_API_SECRET_HERE

# Telegram Bot Token
telegram:
  bot_token: YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: Database URLs (if using external databases)
database:
  url: sqlite:///./data/trading_bot.db