# 🔐 Environment Variables Template for Live Trading
# 
# INSTRUCTIONS:
# 1. Copy this file to: .env (in project root)
# 2. Replace placeholder values with your actual secrets
# 3. NEVER commit this file to version control!
# 4. Add .env to your .gitignore file

# =============================================================================
# KRACKEN API CREDENTIALS (REQUIRED FOR LIVE TRADING)
# =============================================================================
# Get these from: https://www.kraken.com/features/api
# IMPORTANT: Do NOT enable withdrawal permissions for trading bot API keys!

KRAKEN_API_KEY=your_actual_kraken_api_key_here
KRAKEN_API_SECRET=your_actual_kraken_api_secret_here

# =============================================================================
# TELEGRAM BOT SETTINGS (OPTIONAL BUT RECOMMENDED FOR MONITORING)
# =============================================================================
# Get these from @BotFather on Telegram
# Create a bot, then get the token and your user ID(s)

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here_from_botfather
TELEGRAM_ADMIN_USERS=your_telegram_user_id_here,another_user_id_if_needed

# To find your Telegram user ID:
# 1. Start a chat with @userinfobot
# 2. It will reply with your user ID
# 3. Or send any message to @RawDataBot and look for "user id"

# =============================================================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# =============================================================================
# Only needed if you enabled email notifications in config.yaml

EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email_address_here@gmail.com
EMAIL_PASSWORD=your_app_or_app_specific_password_here
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# =============================================================================
# OPTIONAL: CUSTOM CONFIGURATION OVERRIDES
# =============================================================================
# You can override any config value here using the format:
# CONFIG_SECTION_KEY=value
#
# Examples:
# TRADING_DEFAULT_PAIR=ETH/USD
# TRADING_POSITION_SIZE_PERCENT=3.0
# RISK_MAX_DAILY_LOSS_PERCENT=5.0